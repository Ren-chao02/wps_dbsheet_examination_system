// Prisma Schema for 金山多维表格考试系统

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  teacher
  student
}

enum QuestionType {
  create_table
  add_field
  config_view
  create_form
  comprehensive
}

enum Difficulty {
  easy
  medium
  hard
}

enum QuestionStatus {
  draft
  published
  archived
}

enum ExamMode {
  practice
  quiz
  exam
}

enum ExamStatus {
  draft
  published
  in_progress
  ended
  archived
}

enum SubmissionStatus {
  pending
  in_progress
  submitted
  grading
  graded
}

enum Gender {
  MALE
  FEMALE
  UNSET
}

enum AccountStatus {
  ENABLED
  DISABLED
}

enum InvitationStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  PENDING
  PROCESSING
  FINISHED
  FAILED
}

model User {
  id           String  @id @default(uuid()) @db.Uuid
  username     String  @unique @db.VarChar(64)
  passwordHash String  @map("password_hash") @db.VarChar(255)
  realName     String? @map("real_name") @db.VarChar(128)
  role         UserRole
  email        String? @db.VarChar(255)
  avatarUrl    String? @map("avatar_url") @db.VarChar(512)
  studentId    String? @unique @map("student_id") @db.VarChar(64)
  employeeId   String? @unique @map("employee_id") @db.VarChar(64)
  gender       Gender?
  phoneNumber  String? @map("phone_number") @db.VarChar(32)
  accountStatus AccountStatus @default(ENABLED) @map("account_status")
  remark       String?       @db.VarChar(512)
  systemRoleId String?       @map("system_role_id") @db.Uuid
  lastLoginAt  DateTime? @map("last_login_at")
  departmentId String? @map("department_id")
  majorId      String? @map("major_id")
  classRoomId  String? @map("class_room_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  createdQuestions      Question[]           @relation("QuestionCreator")
  createdExams         Exam[]               @relation("ExamCreator")
  submissions          StudentSubmission[]
  gradedSubmissions    StudentSubmission[]  @relation("Grader")
  examSessions         ExamSession[]
  department           Department?          @relation(fields: [departmentId], references: [id])
  major                Major?               @relation(fields: [majorId], references: [id])
  classRoom            ClassRoom?           @relation(fields: [classRoomId], references: [id])
  systemRole           SystemRole?          @relation(fields: [systemRoleId], references: [id])
  createdInvitations   Invitation[]         @relation("InvitationCreator")
  reviewedApplications StudentApplication[] @relation("ApplicationReviewer")
  createdImportTasks   ImportTask[]         @relation("ImportTaskCreator")

  @@map("users")
}

model QuestionCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(128)
  parentId  String?   @map("parent_id") @db.Uuid
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  parent    QuestionCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  QuestionCategory[] @relation("CategoryTree")
  questions Question[]

  @@map("question_categories")
}

model Question {
  id          String         @id @default(uuid()) @db.Uuid
  categoryId  String?        @map("category_id") @db.Uuid
  title       String         @db.VarChar(512)
  description String?        @db.Text
  type        QuestionType
  difficulty  Difficulty     @default(medium)
  score       Int            @default(10)
  answerRules Json           @default("[]") @map("answer_rules")
  hints       String?        @db.Text
  tags        String[]       @default([])
  status      QuestionStatus @default(draft)
  createdBy   String?        @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  category            QuestionCategory?  @relation(fields: [categoryId], references: [id])
  creator             User?              @relation("QuestionCreator", fields: [createdBy], references: [id])
  examQuestions       ExamQuestion[]
  submissionDetails   SubmissionDetail[]

  @@map("questions")
}

model Exam {
  id              String     @id @default(uuid()) @db.Uuid
  title           String     @db.VarChar(256)
  description     String?    @db.Text
  mode            ExamMode   @default(practice)
  durationMinutes Int?       @map("duration_minutes")
  startTime       DateTime?  @map("start_time")
  endTime         DateTime?  @map("end_time")
  totalScore      Int        @default(100) @map("total_score")
  passScore       Int?       @map("pass_score")
  status          ExamStatus @default(draft)
  settings        Json       @default("{}")
  createdBy       String?    @map("created_by") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Relations
  creator       User?               @relation("ExamCreator", fields: [createdBy], references: [id])
  examQuestions ExamQuestion[]
  submissions   StudentSubmission[]
  sessions      ExamSession[]

  @@map("exams")
}

model ExamQuestion {
  id            String @id @default(uuid()) @db.Uuid
  examId        String @map("exam_id") @db.Uuid
  questionId    String @map("question_id") @db.Uuid
  sortOrder     Int    @default(0) @map("sort_order")
  scoreOverride Int?   @map("score_override")

  // Relations
  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([examId, questionId])
  @@map("exam_questions")
}

model StudentSubmission {
  id            String           @id @default(uuid()) @db.Uuid
  examId        String           @map("exam_id") @db.Uuid
  studentId     String           @map("student_id") @db.Uuid
  tableSpaceId  String?          @map("table_space_id") @db.VarChar(256)
  status        SubmissionStatus @default(pending)
  startedAt     DateTime?        @map("started_at")
  submittedAt   DateTime?        @map("submitted_at")
  gradedAt      DateTime?        @map("graded_at")
  totalScore    Int?             @map("total_score")
  graderComment String?          @map("grader_comment") @db.Text
  gradedBy      String?          @map("graded_by") @db.Uuid
  createdAt     DateTime         @default(now()) @map("created_at")

  // Relations
  exam             Exam                 @relation(fields: [examId], references: [id])
  student          User                 @relation(fields: [studentId], references: [id])
  grader           User?                @relation("Grader", fields: [gradedBy], references: [id])
  details          SubmissionDetail[]
  verificationResults VerificationResult[]
  session          ExamSession?

  @@unique([examId, studentId])
  @@map("student_submissions")
}

model SubmissionDetail {
  id           String    @id @default(uuid()) @db.Uuid
  submissionId String    @map("submission_id") @db.Uuid
  questionId   String    @map("question_id") @db.Uuid
  answerJson   Json      @default("{}") @map("answer_json")
  score        Int?
  isCorrect    Boolean?  @map("is_correct")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  submission          StudentSubmission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question            Question             @relation(fields: [questionId], references: [id])
  verificationResults VerificationResult[]

  @@unique([submissionId, questionId])
  @@map("submission_details")
}

model VerificationResult {
  id                   String   @id @default(uuid()) @db.Uuid
  submissionDetailId   String   @map("submission_detail_id") @db.Uuid
  submissionId         String   @map("submission_id") @db.Uuid
  ruleId               String   @map("rule_id") @db.VarChar(64)
  action               String   @db.VarChar(64)
  expected             Json?
  actual               Json?
  passed               Boolean
  score                Int      @default(0)
  errorMessage         String?  @map("error_message") @db.Text
  needsReview          Boolean  @default(false) @map("needs_review")
  verifiedAt           DateTime @default(now()) @map("verified_at")

  // Relations
  submissionDetail SubmissionDetail @relation(fields: [submissionDetailId], references: [id], onDelete: Cascade)
  submission       StudentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("verification_results")
}

model ExamSession {
  id            String    @id @default(uuid()) @db.Uuid
  submissionId  String    @unique @map("submission_id") @db.Uuid
  studentId     String    @map("student_id") @db.Uuid
  examId        String    @map("exam_id") @db.Uuid
  wsConnected   Boolean   @default(false) @map("ws_connected")
  lastHeartbeat DateTime? @map("last_heartbeat")
  ipAddress     String?   @map("ip_address") @db.Inet
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  submission StudentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  student    User              @relation(fields: [studentId], references: [id])
  exam       Exam              @relation(fields: [examId], references: [id])

  @@map("exam_sessions")
}

model Department {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  majors      Major[]
  classRooms  ClassRoom[]
  users       User[]
}

model Major {
  id           String    @id @default(uuid())
  name         String
  code         String
  departmentId String
  description  String?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  classRooms   ClassRoom[]
  users        User[]

  @@unique([departmentId, code])
}

model ClassRoom {
  id           String    @id @default(uuid())
  name         String
  code         String    @unique
  academicYear String
  gradeLevel   Int       @default(1)
  departmentId String
  majorId      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  department   Department @relation(fields: [departmentId], references: [id])
  major        Major      @relation(fields: [majorId], references: [id], onDelete: Cascade)
  students     User[]
  invitations  Invitation[]
}

model Invitation {
  id          String           @id @default(uuid())
  code        String           @unique
  classRoomId String
  createdBy   String   @db.Uuid
  expiresAt   DateTime
  maxUses     Int              @default(0)
  usedCount   Int              @default(0)
  status      InvitationStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())

  classRoom    ClassRoom @relation(fields: [classRoomId], references: [id])
  creator      User      @relation("InvitationCreator", fields: [createdBy], references: [id])
  applications StudentApplication[]
}

model StudentApplication {
  id           String            @id @default(uuid())
  invitationId String
  realName     String
  studentId    String
  phoneNumber  String?
  gender       Gender?
  status       ApplicationStatus @default(PENDING)
  reviewedBy   String?  @db.Uuid
  reviewedAt   DateTime?
  rejectReason String?
  createdAt    DateTime          @default(now())

  invitation   Invitation @relation(fields: [invitationId], references: [id])
  reviewer     User?      @relation("ApplicationReviewer", fields: [reviewedBy], references: [id])
}

model ImportTask {
  id          String       @id @default(uuid())
  type        String
  fileName    String
  taskName    String?      @map("task_name") @db.VarChar(256)
  totalRows   Int          @default(0)
  successRows Int          @default(0)
  failedRows  Int          @default(0)
  status      TaskStatus   @default(PENDING)
  errorFile   String?
  downloadUrl String?      @map("download_url") @db.VarChar(512)
  createdBy   String   @db.Uuid
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  creator     User @relation("ImportTaskCreator", fields: [createdBy], references: [id])
}

model SystemRole {
  id          String   @id @default(uuid()) @db.Uuid
  roleCode    String   @unique @map("role_code") @db.VarChar(64)
  roleName    String   @map("role_name") @db.VarChar(128)
  roleType    String   @default("custom") @map("role_type") @db.VarChar(16)
  description String?  @db.VarChar(512)
  status      String   @default("ACTIVE") @db.VarChar(16)
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions SystemRolePermission[]
  users       User[]

  @@map("system_roles")
}

model SystemRolePermission {
  id         String @id @default(uuid()) @db.Uuid
  roleId     String @map("role_id") @db.Uuid
  moduleCode String @map("module_code") @db.VarChar(64)

  role       SystemRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleCode])
  @@map("system_role_permissions")
}
