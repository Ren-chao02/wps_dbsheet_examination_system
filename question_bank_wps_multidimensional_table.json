tion": "verify_relation_field", "expected": {"fieldName": "所属项目", "relationType": "oneWay", "sourceTable": "任务表", "targetTable": "项目表", "linkMode": "manual"}, "score": 100}], "hints": "单向关联允许A表提取B表数据，但B表不能反向提取A表数据", "tags": ["单向关联", "跨表关联"]}, {"id": "Q017", "title": "配置单向关联字段的自动匹配条件", "description": "在'订单表'和'商品表'之间建立单向关联，设置自动匹配条件：当两表的'商品编号'字段值相同时自动建立关联。", "type": "add_field", "difficulty": "中级", "knowledgeCategory": {"primary": "高级字段与关联", "secondary": "单向关联"}, "answerRules": [{"ruleId": "check_auto_match", "action": "verify_auto_match_condition", "expected": {"relationField": "商品关联", "condition": {"sourceField": "商品编号", "targetField": "商品编号", "operator": "="}}, "score": 100}], "hints": "自动匹配最多可设置3个匹配条件；若匹配结果不唯一会显示多条记录", "tags": ["自动匹配", "关联条件"]}, {"id": "Q018", "title": "创建双向关联字段实现表间互查", "description": "在'学生表'和'课程表'之间创建双向关联字段，使得从任一表都能查看和选择另一表的关联记录。", "type": "add_field", "difficulty": "中级", "knowledgeCategory": {"primary": "高级字段与关联", "secondary": "双向关联"}, "answerRules": [{"ruleId": "check_two_way_relation", "action": "verify_two_way_relation", "expected": {"tableA": "学生表", "tableB": "课程表", "bidirectional": true, "bothTablesHaveRelationField": true}, "score": 100}], "hints": "双向关联插入后，A表和B表都会生成关联字段，双方可以互相访问对方数据", "tags": ["双向关联", "互相关联"]}, {"id": "Q019", "title": "设置关联字段允许多条记录关联", "description": "在单向关联或双向关联字段设置中，开启'允许关联多条记录'开关，使一个任务可以关联多个负责人。", "type": "add_field", "difficulty": "中级", "knowledgeCategory": {"primary": "高级字段与关联", "secondary": "单向关联"}, "answerRules": [{"ruleId": "check_multi_record_link", "action": "verify_multi_record_setting", "expected": {"fieldName": "负责人", "allowMultipleRecords": true}, "score": 100}], "hints": "在关联字段设置界面找到'允许关联多条记录'开关并开启", "tags": ["多记录关联", "一对多关系"]}, {"id": "Q20", "title": "创建引用字段显示关联表的具体字段值", "description": "在已有单向关联字段的基础上，创建引用字段来显示关联表中'单价'字段的具体数值，而非仅显示关联记录名称。", "type": "add_field", "difficulty": "中级", "knowledgeCategory": {"primary": "高级字段与关联", "secondary": "查找引用统计"}, "answerRules": [{"ruleId": "check_reference_field", "action": 