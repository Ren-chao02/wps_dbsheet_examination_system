{"metadata": {"version": "1.0", "source": "WPS多维表格官方教程", "createdDate": "2026-06-17", "totalQuestions": 50, "categories": {"primary": ["基础概念与界面操作", "字段类型与配置", "视图操作与管理", "高级字段与关联", "自动化与AI功能", "综合应用"], "secondary": ["新建表格", "界面导航", "基础字段", "业务字段", "AI字段", "高级字段", "表格视图", "看板视图", "筛选排序分组", "仪表盘", "单向关联", "双向关联", "查找引用统计", "自动化工作流", "AI助手", "数据管理"]}, "difficultyLevels": {"初级": "easy", "中级": "medium", "高级": "hard"}}, "questions": [{"id": "Q001", "title": "创建空白多维表格并认识基本界面结构", "description": "请创建一个新的空白多维表格，并能够正确识别和描述多维表格界面的五个核心区域：左侧导航面板、顶部菜单栏、数据表字段区、数据记录区域、底部状态栏。", "type": "create_table", "difficulty": "初级", "knowledgeCategory": {"primary": "基础概念与界面操作", "secondary": "新建表格"}, "answerRules": [{"ruleId": "check_table_created", "action": "verify_table_exists", "expected": true, "score": 30}, {"ruleId": "check_interface_regions", "action": "verify_interface_elements", "expected": {"leftPanel": true, "topMenu": true, "fieldArea": true, "dataArea": true, "statusBar": true}, "score": 70}], "hints": "从WPS主界面点击'新建'→'应用服务'→'多维表格'→'空白多维表格'", "tags": ["基础操作", "界面认知", "入门"]}, {"id": "Q002", "title": "在左侧导航面板中创建新的数据表", "description": "在已创建的多维表格中，通过左侧导航面板的'+'按钮创建一个新的数据表，命名为'员工信息表'。", "type": "create_table", "difficulty": "初级", "knowledgeCategory": {"primary": "基础概念与界面操作", "secondary": "界面导航"}, "answerRules": [{"ruleId": "check_table_name", "action": "verify_table_name", "expected": "员工信息表", "score": 100}], "hints": "点击左侧导航面板下方的'+'号，选择'数据表'选项", "tags": ["数据表创建", "左侧导航"]}, {"id": "Q003", "title": "使用两种方式新建文本字段", "description": "在数据表中使用两种不同的方式新建文本字段：方式一：点击表头右侧的'+'按钮；方式二：选中列后右键点击。将字段命名为'姓名'。", "type": "add_field", "difficulty": "初级", "knowledgeCategory": {"primary": "字段类型与配置", "secondary": "基础字段"}, "answerRules": [{"ruleId": "check_field_exists", "action": "verify_field_exists", "expected": {"fieldName": "姓名", "fieldType": "text"}, "score": 100}], "hints": "方式一：点击表头最右侧的'+'号；方式二：右键点击现有字段标题", "tags": ["文本字段", "字段创建", "多种方式"]}, {"id": "Q004", "title": "创建数字字段并设置小数位数格式", "description": "新建一个数字字段命名为'月薪'，并设置数字格式为保留2位小数。", "type": "add_field", "difficulty": "初级", "knowledgeCategory": {"primary": "字段类型与配置", "secondary": "基础字段"}, "answerRules": [{"ruleId": "check_field_type", "action": "verify_field_type", "expected": {"fieldName": "月薪", "type": "number", "decimalPlaces": 2}, "score": 100}], "hints": "新建数字字段后，在字段设置页面找到数字格式选项，设置精确到小数点后2位", "tags": ["数字字段", "格式设置"]}, {"id": "Q005", "title": "创建单选项字段并添加选项值", "description": "新建一个单选项字段命名为'部门'，并添加以下选项值：'技术部'、'市场部'、'财务部'、'人事部'。", "type": "add_field", "difficulty": "初级", "knowledgeCategory": {"primary": "字段类型与配置", "secondary": "基础字段"}, "answerRules": [{"ruleId": "check_single_select", "action": "verify_single_select_options", "expected": {"fieldName": "部门", "options": ["技术部", "市场部", "财务部", "人事部"]}, "score": 100}], "hints": "选择单选项字段类型后，在字段设置界面逐个输入选项值", "tags": ["单选项字段", "选项配置"]}, {"id": "Q006", "title": "创建日期字段并设置日期格式", "description": "新建一个日期字段命名为'入职日期'，日期格式设置为'年-月-日'（如：2024-01-15）。", "type": "add_field", "difficulty": "初级", "knowledgeCategory": {"primary": "字段类型与配置", "secondary": "基础字段"}, "answerRules": [{"ruleId": "check_date_field", "action": "verify_date_format", "expected": {"fieldName": "入职日期", "format": "YYYY-MM-DD"}, "score": 100}], "hints": "选择日期字段后，可在字段设置中选择显示格式", "tags": ["日期字段", "日期格式"]}, {"id": "Q007", "title": "为文本字段设置默认值", "description": "对'姓名'字段设置默认值为'待填写'，使得新增记录时该字段自动填充此值。", "type": "add_field", "difficulty": "初级", "knowledgeCategory": {"primary": "字段类型与配置", "secondary": "基础字段"}, "answerRules": [{"ruleId": "check_default_value", "action": "verify_default_value", "expected": {"fieldName": "姓名", "defaultValue": "待填写"}, "score": 100}], "hints": "打开字段设置页面，找到'默认值'设置栏进行配置", "tags": ["默认值", "字段属性"]}, {"id": "Q008", "title": "设置字段的禁止录入重复值功能", "description": "新建一个'工号'文本字段，并开启'禁止录入重复值'功能，确保每个员工的工号唯一。", "type": "add_field", "difficulty": "中级", "knowledgeCategory": {"primary": "字段类型与配置", "secondary": "基础字段"}, "answerRules": [{"ruleId": "check_unique_constraint", "action": "verify_unique_constraint", "expected": {"fieldName": "工号", "uniqueEnabled": true}, "score": 100}], "hints": "注意：同一表格只能有一个字段设置禁止重复值；且该字段下不能有已存在的重复数据", "tags": ["唯一约束", "重复值限制"]}, {"id": "Q009", "title": "创建多选项字段用于技能标签", "description": "新建一个多选项字段命名为'技能标签'，添加选项：'Python'、'Java'、'JavaScript'、'SQL'、'Excel'，允许选择多个选项。", "type": "add_field", "difficulty": "初级", "knowledgeCategory": {"primary": "字段类型与配置", "secondary": "基础字段"}, "answerRules": [{"ruleId": "check_multi_select", "action": "verify_multi_select_options", "expected": {"fieldName": "技能标签", "options": ["Python", "Java", "JavaScript", "SQL", "Excel"], "allowMultiple": true}, "score": 100}], "hints": "多选项字段与单选项类似，但允许同时勾选多个值", "tags": ["多选项字段", "标签管理"]}, {"id": "Q010", "title": "创建联系人字段并理解其用途", "description": "新建一个联系人字段命名为'直属上级'，说明联系人字段的主要用途和特点。", "type": "add_field", "difficulty": "初级", "knowledgeCategory": {"primary": "字段类型与配置", "secondary": "基础字段"}, "answerRules": [{"ruleId": "check_contact_field", "action": "verify_contact_field", "expected": {"fieldName": "直属上级", "type": "contact"}, "score": 80}, {"ruleId": "check_understanding", "action": "verify_text_description", "expectedContains": ["组织架构", "人员关联", "协作"], "score": 20}], "hints": "联系人字段用于关联系统内其他用户，便于协作和权限管理", "tags": ["联系人字段", "人员管理"]}, {"id": "Q011", "title": "创建富文本字段记录详细说明", "description": "新建一个富文本字段命名为'工作经历'，能够支持录入包含格式的长文本内容（如加粗、列表等）。", "type": "add_field", "difficulty": "初级", "knowledgeCategory": {"primary": "字段类型与配置", "secondary": "基础字段"}, "answerRules": [{"ruleId": "check_rich_text_field", "action": "verify_rich_text_field", "expected": {"fieldName": "工作经历", "type": "richText"}, "score": 100}], "hints": "富文本字段支持文字格式化，适合记录详细描述信息", "tags": ["富文本字段", "长文本"]}, {"id": "Q012", "title": "创建图片和附件字段", "description": "分别创建'头像'（图片字段）和'证件附件'（附件字段），理解两者的区别和应用场景。", "type": "add_field", "difficulty": "初级", "knowledgeCategory": {"primary": "字段类型与配置", "secondary": "基础字段"}, "answerRules": [{"ruleId": "check_image_field", "action": "verify_image_field", "expected": {"fieldName": "头像", "type": "image"}, "score": 50},